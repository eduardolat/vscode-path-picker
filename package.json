{
  "name": "quick-path-picker",
  "displayName": "Quick Path Picker",
  "version": "0.1.0",
  "description": "Fuzzy-search any file or folder in your workspace and copy its relative or absolute path with an optional prefix",
  "icon": "./assets/logo.png",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:quickPathPicker.copyPath"
  ],
  "extensionKind": [
    "ui"
  ],
  "contributes": {
    "commands": [
      {
        "command": "quickPathPicker.copyPath",
        "category": "Quick Path Picker",
        "title": "Copy Path (Files & Folders)"
      }
    ],
    "configuration": {
      "title": "Quick Path Picker",
      "properties": {
        "quickPathPicker.pathStyle": {
          "type": "string",
          "enum": [
            "relative",
            "absolute"
          ],
          "default": "relative",
          "scope": "application",
          "ignoreSync": true,
          "description": "Controls if copied paths are relative to workspace root or absolute OS paths."
        },
        "quickPathPicker.prefix": {
          "type": "string",
          "default": "@",
          "scope": "application",
          "ignoreSync": true,
          "description": "Prefix added before the copied path. Use an empty string to disable it."
        }
      }
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eduardolat/vscode-path-picker.git"
  },
  "keywords": [
    "absolute path",
    "clipboard",
    "copy path",
    "file path",
    "file picker",
    "folder path",
    "path",
    "path alias",
    "path copy",
    "path utilities",
    "path picker",
    "productivity",
    "relative path",
    "resource picker",
    "vscode",
    "vscode clipboard",
    "vscode extension",
    "vscode path",
    "workspace path",
    "workspace root"
  ],
  "author": "Luis Eduardo Jerez",
  "publisher": "eduardolat",
  "license": "MIT",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/eduardolat/vscode-path-picker/issues"
  },
  "homepage": "https://github.com/eduardolat/vscode-path-picker#readme",
  "scripts": {
    "dev": "rm -rf ./dist && node esbuild.js --watch",
    "build": "rm -rf ./dist && node esbuild.js --production",
    "package": "npm run build && rm -rf *.vsix && vsce package",
    "package:ls": "vsce ls",
    "format": "npm run format:dprint && npm run format:biome",
    "format:dprint": "dprint fmt --config ./dprint.json --log-level warn",
    "format:biome": "biome format --write --config-path ./biome.json --log-level warn --no-errors-on-unmatched .",
    "lint": "npm run lint:dprint && npm run lint:biome",
    "lint:dprint": "dprint check --config ./dprint.json --log-level warn",
    "lint:biome": "biome check --config-path ./biome.json --log-level warn --no-errors-on-unmatched .",
    "test": "node --test",
    "ci": "npm run lint && npm run test"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@vscode/vsce": "3.9.1",
    "dprint": "0.54.0",
    "esbuild": "0.28.0"
  }
}
